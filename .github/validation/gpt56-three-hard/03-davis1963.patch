-/-- Diagonal pinch associated with a complete orthogonal projection family. -/
-noncomputable def familyPinch {m : ℕ} (P : OrthoProjFamily 𝕜 E m)
-    (H : E →ₗ[𝕜] E) : E →ₗ[𝕜] E :=
