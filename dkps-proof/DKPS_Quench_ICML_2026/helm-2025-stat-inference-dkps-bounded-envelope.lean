  haveI : OpensMeasurableSpace S := by infer_instance
  haveI : IsFiniteMeasure μ := by infer_instance
  haveI : μ.InnerRegular := by infer_instance
  -- handle ε = ⊤ separately (then goal is trivial)
  by_cases htop : ε = ⊤
  · subst htop
    refine ⟨∅, isCompact_empty, ?_⟩
    -- P{ω | Y ω ∉ ∅} = P univ < ⊤
    -- and P univ ≠ ⊤ since P is finite (probability)
    simp [lt_top_iff_ne_top]
  -- tightness of {μ}
  have hT : IsTightMeasureSet ({μ} : Set (Measure S)) :=
    MeasureTheory.isTightMeasureSet_singleton_of_innerRegular (μ := μ)
  have hiff :=
    (MeasureTheory.isTightMeasureSet_iff_exists_isCompact_measure_compl_le
      (S := ({μ} : Set (Measure S))))
  -- positivity of ε/2 (uses your div_pos signature: a≠0 and b≠⊤)
