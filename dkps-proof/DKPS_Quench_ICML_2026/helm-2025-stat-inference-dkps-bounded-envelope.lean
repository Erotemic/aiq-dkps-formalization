    have hs : MeasurableSet (Kᶜ) := hKmeas.compl
    have hm : (Measure.map Y P) (Kᶜ) = P (Y ⁻¹' (Kᶜ)) :=
        MeasureTheory.Measure.map_apply (μ := P) (f := Y) h_meas_Y hs
    simpa [μ, Set.preimage_compl] using hm
  have h_le : P {ω | Y ω ∉ K} ≤ ε / 2 := by
    have hset : {ω | Y ω ∉ K} = (Y ⁻¹' K)ᶜ := by
        ext ω; rfl
    -- rewrite hμK using h_event
    have : P (Y ⁻¹' K)ᶜ ≤ ε / 2 := by
        simpa [h_event] using hμK
    simpa [hset] using this  -- prove ε/2 < ε (now we can use htop : ε ≠ ⊤)
  have hb0 : (2 : ENNReal) ≠ 0 := by norm_num
  have hbt : (2 : ENNReal) ≠ ⊤ := by norm_num
  have h_half_lt : ε / 2 < ε := by
    -- div_lt_iff: (c/b < a) ↔ (c < a*b)
    have hdiv :
        (ε / (2 : ENNReal) < ε) ↔ (ε < ε * (2 : ENNReal)) := by
      simpa using
        (ENNReal.div_lt_iff (a := ε) (b := (2 : ENNReal)) (c := ε)
          (h0 := Or.inl hb0) (ht := Or.inl hbt))
    -- show ε < ε*2 via mul strictness on the right
    have h1lt2 : (1 : ENNReal) < (2 : ENNReal) := by norm_num
    have hmul : ε * (1 : ENNReal) < ε * (2 : ENNReal) := by
      -- mul_lt_mul_right: multiply strict inequality on the right by ε
      -- signature in your build: mul_lt_mul_left / left' exist; right should exist per deprecation note.
      simpa [mul_assoc] using (ENNReal.mul_lt_mul_right (a := ε) (h0 := ne_of_gt ε_pos) (hinf := htop) h1lt2)
    have : ε < ε * (2 : ENNReal) := by simpa [mul_one] using hmul
    exact hdiv.mpr this
  -- finish: P(event) ≤ ε/2 < ε
  exact lt_of_le_of_lt h_le h_half_lt
