/-
If the baseline MSE is positive, then for sufficiently large n and r, the DKPS MSE is strictly less than the baseline MSE with high probability.
This follows from the fact that the DKPS MSE converges to 0 (in probability), so it eventually becomes smaller than any positive constant.
-/
open Metric MeasureTheory ProbabilityTheory Filter Topology

/--
Main Theorem (Query-efficiency via DKPS nearest neighbor):
If the baseline subset-score estimator has strictly positive MSE, then for sufficiently large n and r,
the DKPS nearest-neighbor predictor achieves strictly smaller MSE with high probability over the training data.
-/
theorem quench_query_efficiency
  {F : Type*} [MeasurableSpace F] (Pf : Measure F) [IsProbabilityMeasure Pf]
  {d : ℕ} (ψ : F → EuclideanSpace ℝ (Fin d)) (hψ : Measurable ψ)
  {Ω_est : Type*} [MeasurableSpace Ω_est] (P_est : Measure Ω_est) [IsProbabilityMeasure P_est]
  (ψhat : ℕ → Ω_est → F → EuclideanSpace ℝ (Fin d))
  (h_ψhat_meas : ∀ r, Measurable (fun p : Ω_est × F => ψhat r p.1 p.2))
  (y : F → ℝ) (hy_meas : Measurable y) (hy_bound : ∀ f, |y f| ≤ 1)
  (yQ : F → ℝ) (hyQ_meas : Measurable yQ)
  (γ : ℝ) (hγ : 0 < γ)
  (h_lip : ∀ f f', |y f - y f'| ≤ γ * dist (ψ f) (ψ f'))
  (h_conc : DKPS_concentration_hypothesis ψ Ω_est P_est ψhat)
  (h_dense : Model_distribution_denseness Pf ψ)
  (h_baseline_pos : MSE_baseline Pf yQ y > 0) :
  ∀ η > 0, ∃ N, ∀ n ≥ N, ∃ R, ∀ r ≥ R,
    let μ_train := (Measure.pi (fun _ : Fin n => Pf)).prod P_est
    μ_train { p | MSE_DKPS_canonical Pf n p.1 y (ψhat r p.2) < MSE_baseline Pf yQ y } ≥ ENNReal.ofReal (1 - η) := by
      intro η hη_pos
      obtain ⟨ N, hN ⟩ : ∃ N : ℕ, ∀ n ≥ N, ∃ R : ℕ, ∀ r ≥ R,
        let μ_train := (Measure.pi (fun _ : Fin n => Pf)).prod P_est;
        μ_train { p | MSE_DKPS_canonical Pf n p.1 y (ψhat r p.2) ≤ MSE_baseline Pf yQ y / 2 } ≥ ENNReal.ofReal (1 - η) := by
          convert dkps_mse_convergence_canonical Pf ψ hψ P_est ψhat h_ψhat_meas y hy_meas hy_bound γ hγ h_lip h_conc h_dense ( MSE_baseline Pf yQ y / 2 ) ( half_pos h_baseline_pos ) η hη_pos using 1
      generalize_proofs at *; (
      exact ⟨ N, fun n hn => by obtain ⟨ R, hR ⟩ := hN n hn; exact ⟨ R, fun r hr => le_trans ( hR r hr ) ( MeasureTheory.measure_mono fun p hp => lt_of_le_of_lt hp.out ( half_lt_self h_baseline_pos ) ) ⟩ ⟩)

/-
Checking the existence of the main theorems.
-/
#check dkps_mse_convergence_canonical
#check dkps_mse_convergence_canonical_v2
#check quench_query_efficiency

