/-
Definition of the nearest neighbor index in the estimated perspective space.
It selects the index i such that the distance between the estimated perspective of the reference model i and the target model is minimized.
-/
open Metric MeasureTheory ProbabilityTheory Classical

noncomputable def nn_index {F : Type*} {d : ℕ} (n : ℕ) [NeZero n] (refs : Fin n → F) (target : F) (ψhat : F → EuclideanSpace ℝ (Fin d)) : Fin n :=
  let s : Finset (Fin n) := Finset.univ
  let f := fun i => dist (ψhat (refs i)) (ψhat target)
  haveI : Nonempty (Fin n) := Fin.pos_iff_nonempty.1 (NeZero.pos n)
  Classical.choose (Finset.exists_min_image s f Finset.univ_nonempty)

/-
Property of the nearest neighbor index: it minimizes the distance in the estimated perspective space.
-/
theorem nn_index_spec {F : Type*} {d : ℕ} (n : ℕ) [NeZero n] (refs : Fin n → F) (target : F) (ψhat : F → EuclideanSpace ℝ (Fin d)) :
    let i_star := nn_index n refs target ψhat
    ∀ j : Fin n, dist (ψhat (refs i_star)) (ψhat target) ≤ dist (ψhat (refs j)) (ψhat target) := by
  convert Classical.choose_spec ( Finset.exists_min_image Finset.univ ( fun i => Dist.dist ( ψhat ( refs i ) ) ( ψhat target ) ) Finset.univ_nonempty ) |> fun h => h.2;
  simp +decide [ nn_index ]

/-
The nearest neighbor predictor predicts the score of the target model to be the score of the reference model with the closest estimated perspective.
-/
noncomputable def nn_predictor {F : Type*} {d : ℕ} (n : ℕ) [NeZero n] (refs : Fin n → F) (target : F) (ψhat : F → EuclideanSpace ℝ (Fin d)) (y : F → ℝ) : ℝ :=
  y (refs (nn_index n refs target ψhat))

