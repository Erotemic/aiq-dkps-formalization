  {F : Type*} {d : ℕ}
  (ψ : F → EuclideanSpace ℝ (Fin d))
  (Ω_est : Type*) [MeasurableSpace Ω_est] (P_est : Measure Ω_est)
  (ψhat : ℕ → Ω_est → F → EuclideanSpace ℝ (Fin d)) : Prop :=
  ∀ (n : ℕ) (ε : ℝ), 0 < ε →
    ∃ R, ∀ r ≥ R, ∀ (refs : Fin n → F) (target : F),
