  {F : Type*} [MeasurableSpace F] (Pf : Measure F)
  {d : ℕ} (ψ : F → EuclideanSpace ℝ (Fin d)) : Prop :=
  ∀ f : F, ∀ ε > 0, Pf { f' | dist (ψ f') (ψ f) ≤ ε } > 0

