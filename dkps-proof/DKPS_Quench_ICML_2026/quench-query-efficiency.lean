  (h_conc_refs : ∀ i, dist (ψhat (refs i)) (ψ (refs i)) ≤ c)
  (h_conc_target : dist (ψhat target) (ψ target) ≤ c)
  (h_close : ∃ j, dist (ψ (refs j)) (ψ target) ≤ ε')
  (h_lip : ∀ f f', |y f - y f'| ≤ γ * dist (ψ f) (ψ f')) :
  |nn_predictor n refs target ψhat y - y target| ≤ γ * (4 * c + ε') := by
