        intro K hK ε hε_pos;
        have := hK.elim_nhds_subcover;
        -- By the definition of continuity at a point, for each $y \in K$, there exists $\delta_y > 0$ such that if $dist x y < \delta_y$, then $dist (f x) (f y) < \epsilon / 2$.
        have h_cont_at : ∀ y ∈ K, ∃ δ_y > 0, ∀ x, dist x y < δ_y → dist (f x) (f y) < ε / 2 := by
