lemma uniform_continuity_on_compact_approx {S S' : Type*}
    [PseudoMetricSpace S] [PseudoMetricSpace S']
    (f : S → S') (K : Set S) (h_cont : Continuous f) (h_compact : IsCompact K) :
    ∀ ε > 0, ∃ δ > 0, ∀ y ∈ K, ∀ x, dist x y < δ → dist (f x) (f y) < ε := by
      intro ε εpos;
      by_contra! h_contra;
      choose! y hy x hx using h_contra;
      -- Since $K$ is compact, the sequence $\{y_{1/n}\}$ has a convergent subsequence $\{y_{1/n_k}\}$ that converges to some $y \in K$.
      obtain ⟨y', hy', h_subseq⟩ : ∃ y' ∈ K, ∃ (nk : ℕ → ℕ), StrictMono nk ∧ Filter.Tendsto (fun k => y (1 / (nk k + 1)) (by positivity)) Filter.atTop (nhds y') := by
        have := h_compact.isSeqCompact fun n => hy ( 1 / ( n + 1 ) ) ( by positivity );
        tauto;
      -- Since $x_{1/n_k}$ converges to $y'$, we have $f(x_{1/n_k}) \to f(y')$ and $f(y_{1/n_k}) \to f(y')$.
      obtain ⟨nk, hnk_mono, hnk_conv⟩ := h_subseq;
      have hx_conv : Filter.Tendsto (fun k => x (1 / (nk k + 1)) (by positivity)) Filter.atTop (nhds y') := by
        have hx_conv : Filter.Tendsto (fun k => dist (x (1 / (nk k + 1)) (by positivity)) (y (1 / (nk k + 1)) (by positivity))) Filter.atTop (nhds 0) := by
          exact squeeze_zero ( fun _ => dist_nonneg ) ( fun k => le_of_lt ( hx _ ( by positivity ) |>.1 ) ) ( tendsto_one_div_add_atTop_nhds_zero_nat.comp hnk_mono.tendsto_atTop );
        -- show x_k → y' using dist(x_k,y_k) → 0 and y_k → y'
        refine Metric.tendsto_nhds.2 ?_
        intro ε εpos
        -- y_k → y' gives eventually dist(y_k,y') < ε/2
        have hy' : ∀ᶠ k in Filter.atTop,
            dist (y (1 / (nk k + 1)) (by positivity)) y' < ε / 2 := by
          have := (Metric.tendsto_nhds.1 hnk_conv) (ε / 2) (by linarith)
          simpa [Metric.ball, dist_comm] using this
        -- dist(x_k,y_k) → 0 gives eventually dist(x_k,y_k) < ε/2
        have hxy' : ∀ᶠ k in Filter.atTop,
            dist (x (1 / (nk k + 1)) (by positivity))
                 (y (1 / (nk k + 1)) (by positivity)) < ε / 2 := by
          -- your hx_conv was dist(...) → 0; unpack it
          have := (Metric.tendsto_nhds.1 hx_conv) (ε / 2) (by linarith)
          simpa [Metric.ball] using this
        -- combine via triangle inequality
        filter_upwards [hy', hxy'] with k hyk hxyk
        have : dist (x (1 / (nk k + 1)) (by positivity)) y' < ε := by
            -- triangle inequality
            have htri :
                dist (x (1 / (nk k + 1)) (by positivity)) y'
                    ≤ dist (x (1 / (nk k + 1)) (by positivity))
                            (y (1 / (nk k + 1)) (by positivity))
                    + dist (y (1 / (nk k + 1)) (by positivity)) y' :=
                dist_triangle _ _ _
            -- add the two strict bounds
            have hsum :
                dist (x (1 / (nk k + 1)) (by positivity))
                        (y (1 / (nk k + 1)) (by positivity))
                    + dist (y (1 / (nk k + 1)) (by positivity)) y' < ε := by
                have h := add_lt_add hxyk hyk   -- < ε/2 + ε/2
                -- turn ε/2 + ε/2 into ε
                -- (this is pure arithmetic, so nlinarith is safe here)
                have : (ε / 2 : ℝ) + (ε / 2) = ε := by nlinarith
                simpa [this, add_comm, add_left_comm, add_assoc] using h
            exact lt_of_le_of_lt htri hsum
        -- convert to membership in ball
        simpa [Metric.ball] using this
      have hy_conv : Filter.Tendsto (fun k => y (1 / (nk k + 1)) (by positivity)) Filter.atTop (nhds y') := by
        exact hnk_conv;
      have hf_conv : Filter.Tendsto (fun k => f (x (1 / (nk k + 1)) (by positivity))) Filter.atTop (nhds (f y')) := by
        exact h_cont.continuousAt.tendsto.comp hx_conv;
      have hf_conv' : Filter.Tendsto (fun k => f (y (1 / (nk k + 1)) (by positivity))) Filter.atTop (nhds (f y')) := by
        exact h_cont.continuousAt.tendsto.comp hy_conv;
      exact absurd ( le_of_tendsto_of_tendsto' tendsto_const_nhds ( Filter.Tendsto.dist hf_conv hf_conv' ) fun k => hx _ _ |>.2 ) ( by simp +decide [ εpos ] )
/-
Lemma: Continuous mapping theorem for convergence in probability. If X_u converges to Y in probability and f is continuous, then f(X_u) converges to f(Y) in probability.
-/
/--
Lemma: Continuous mapping theorem for convergence in probability.
If `X_u → Y` in probability and `f` is continuous, then `f(X_u) → f(Y)` in probability.
-/
lemma continuous_prob_convergence_lemma {Ω : Type*} [MeasurableSpace Ω]
    (P : Measure Ω) [IsProbabilityMeasure P]
    {S S' : Type*}
    [PseudoMetricSpace S] [MeasurableSpace S] [OpensMeasurableSpace S] [SecondCountableTopology S]
    [T2Space S] [LocallyCompactSpace S] [BorelSpace S]
    [PseudoMetricSpace S'] [MeasurableSpace S'] [OpensMeasurableSpace S']
    (X : ℕ → Ω → S) (Y : Ω → S) (f : S → S')
    (h_meas_X : ∀ u, Measurable (X u))
    (h_meas_Y : Measurable Y)
    (h_cont : Continuous f)
    (h_conv : ConvergesInProbabilityToZero P (fun u ω => dist (X u ω) (Y ω))) :
    ConvergesInProbabilityToZero P (fun u ω => dist (f (X u ω)) (f (Y ω))) := by
      exact continuous_prob_convergence P X Y f h_meas_X h_meas_Y h_cont h_conv
/-
Lemma: The risk using estimated embeddings is invariant under affine isometries of the embeddings.
-/
/--
Lemma: The risk using estimated embeddings is invariant under affine isometries of the embeddings.
-/
lemma risk_est_invariant (n d d' : ℕ)
    (P : Measure (E d × Y d'))
    (learn : LearningRule n d d')
    (loss : LossFunction d')
    (psi_hat : (Fin (n + 1) → E d × Y d') → Fin (n + 1) → E d)
    (e : E d ≃ᵃⁱ[ℝ] E d)
    (h_inv : InvariantToAffineIsometries n d d' learn) :
    risk_est n d d' P learn loss (fun ω i => e (psi_hat ω i)) = risk_est n d d' P learn loss psi_hat := by
      unfold risk_est;
      simp +decide;
      congr! 2;
      convert rfl using 2;
      exact h_inv e _ _ ▸ rfl
/-
Lemma: The transformed estimated embeddings converge to the true embeddings in probability.
-/
/--
Lemma: The transformed estimated embeddings converge to the true embeddings in probability.
-/
lemma transformed_embeddings_converge (n d d' : ℕ)
    (P : Measure (E d × Y d'))
    (psi_hat : ℕ → (Fin (n + 1) → E d × Y d') → Fin (n + 1) → E d)
    (h_align : DKPSAlignmentConsistency n d d' P psi_hat) :
    ∃ (e : ℕ → E d ≃ᵃⁱ[ℝ] E d),
      ConvergesInProbabilityToZero (Measure.pi (fun _ : Fin (n + 1) => P))
        (fun u ω => ⨆ i : Fin (n + 1), dist ((e u).symm (psi_hat u ω i)) ((ω i).1)) := by
          obtain ⟨ e, he ⟩ := h_align;
          refine' ⟨ e, fun ε hε => _ ⟩;
          -- Since $e_u$ is an isometry, the distance between $e_u^{-1}(\psi_hat u \omega i)$ and $\omega i$ is equal to the distance between $\psi_hat u \omega i$ and $e_u(\omega i)$.
          have h_dist_eq : ∀ u ω i, dist (((e u).symm : E d → E d) (psi_hat u ω i)) (ω i).1 = dist (psi_hat u ω i) (e u (ω i).1) := by
            intro u ω i; exact (by
            rw [ ← ( e u ).isometry.dist_eq ] ; aesop;);
          simpa [ h_dist_eq ] using he ε hε
/-
Assumption that the labels y are almost surely contained in a compact set.
-/
def combined_loss_fn (n d d' : ℕ)
    (learn : LearningRule n d d')
    (loss : LossFunction d') :
    ((Fin (n + 1) → E d) × (Fin (n + 1) → Y d')) → ℝ :=
  fun p =>
    let psis := p.1
    let ys := p.2
    let train := fun i : Fin n => (psis (Fin.castSucc i), ys (Fin.castSucc i))
    let test_psi := psis (Fin.last n)
    let test_y := ys (Fin.last n)
    loss (learn train test_psi) test_y
lemma combined_loss_continuous (n d d' : ℕ)
    (learn : LearningRule n d d')
    (loss : LossFunction d')
    (h_cont_learn : ContinuousLearningRule n d d' learn)
    (h_cont_loss : ContinuousLoss d' loss) :
    Continuous (combined_loss_fn n d d' learn loss) := by
      unfold combined_loss_fn;
      unfold ContinuousLearningRule ContinuousLoss at *;
      fun_prop
/-
Lemma: The distance between two pairs with the same second component is the distance between their first components.
-/
lemma dist_prod_same_snd {α β : Type*} [PseudoMetricSpace α] [PseudoMetricSpace β] (x x' : α) (y : β) :
    dist (x, y) (x', y) = dist x x' := by
      simp +zetaDelta at *
/-
Lemma: If X_u converges to X_true in probability, then (X_u, Y) converges to (X_true, Y) in probability.
-/
lemma pair_convergence_in_prob {Ω A B : Type*} [MeasurableSpace Ω]
    (P : Measure Ω)
    [PseudoMetricSpace A] [PseudoMetricSpace B]
    (X : ℕ → Ω → A) (X_true : Ω → A)
    (Y : Ω → B)
    (h_conv : ConvergesInProbabilityToZero P (fun u ω => dist (X u ω) (X_true ω))) :
    ConvergesInProbabilityToZero P (fun u ω => dist (X u ω, Y ω) (X_true ω, Y ω)) := by
      simp_all +decide
/-
Lemma: The loss using estimated embeddings converges in probability to the loss using true embeddings.
-/
lemma loss_converges_in_prob (n d d' : ℕ)
    (P : Measure (E d × Y d')) [IsProbabilityMeasure P]
    (learn : LearningRule n d d')
    (loss : LossFunction d')
    (psi_hat : ℕ → (Fin (n + 1) → E d × Y d') → Fin (n + 1) → E d)
    (h_meas_psi : ∀ u, Measurable (psi_hat u))
    (h_conv : ConvergesInProbabilityToZero (Measure.pi (fun _ : Fin (n + 1) => P))
      (fun u ω => ⨆ i : Fin (n + 1), dist (psi_hat u ω i) ((ω i).1)))
    (h_cont_learn : ContinuousLearningRule n d d' learn)
    (h_cont_loss : ContinuousLoss d' loss) :
    ConvergesInProbabilityToZero (Measure.pi (fun _ : Fin (n + 1) => P))
      (fun u ω => dist
        (combined_loss_fn n d d' learn loss (psi_hat u ω, fun i => (ω i).2))
        (combined_loss_fn n d d' learn loss (fun i => (ω i).1, fun i => (ω i).2))) := by
          -- Apply the continuous mapping theorem to conclude the proof.
          apply continuous_prob_convergence_lemma;
          · fun_prop;
          · fun_prop;
          · exact combined_loss_continuous n d d' learn loss h_cont_learn h_cont_loss;
          · simp_all +decide [ dist_eq_norm, Prod.norm_def ];
            convert h_conv using 1;
            ext u ω;
            rw [ @ciSup_eq_of_forall_le_of_forall_lt_exists_gt ];
            · exact fun i => by simpa using norm_le_pi_norm ( psi_hat u ω - fun i => ( ω i |>.1 ) ) i;
            · intro w hw;
              contrapose! hw;
              exact pi_norm_le_iff_of_nonneg ( by linarith [ show 0 ≤ w by exact le_trans ( norm_nonneg _ ) ( hw 0 ) ] ) |>.2 hw
/-
Lemma: The risk is equal to the estimated risk when the estimated embeddings are the true embeddings.
-/
lemma risk_eq_risk_est_true (n d d' : ℕ)
    (P : Measure (E d × Y d'))
    (learn : LearningRule n d d')
    (loss : LossFunction d') :
    risk n d d' P learn loss = risk_est n d d' P learn loss (fun ω i => (ω i).1) := by
  simp [risk, risk_est]
/-

Definitions of the loss functions for estimated and true embeddings.
-/
def loss_est_fn (n d d' : ℕ)
    (learn : LearningRule n d d')
    (loss : LossFunction d')
    (psi_hat : ℕ → (Fin (n + 1) → E d × Y d') → Fin (n + 1) → E d)
    (u : ℕ) : (Fin (n + 1) → E d × Y d') → ℝ :=
  fun ω => combined_loss_fn n d d' learn loss (psi_hat u ω, fun i => (ω i).2)
def loss_true_fn (n d d' : ℕ)
    (learn : LearningRule n d d')
    (loss : LossFunction d') :
    (Fin (n + 1) → E d × Y d') → ℝ :=
  fun ω => combined_loss_fn n d d' learn loss (fun i => (ω i).1, fun i => (ω i).2)
/-
Lemma: If estimated embeddings converge to true embeddings in probability, then the risk converges.
-/
/-
Lemma: If estimated embeddings converge to true embeddings in probability and the loss is bounded, then the
expected risk converges.
-/
lemma risk_convergence_of_aligned_embeddings (n d d' : ℕ)
    (P : Measure (E d × Y d')) [IsProbabilityMeasure P]
    (learn : LearningRule n d d')
    (loss : LossFunction d')
    (psi_hat : ℕ → (Fin (n + 1) → E d × Y d') → Fin (n + 1) → E d)
    (h_meas_psi : ∀ u, Measurable (psi_hat u))
    (h_conv : ConvergesInProbabilityToZero (Measure.pi (fun _ : Fin (n + 1) => P))
      (fun u ω => ⨆ i : Fin (n + 1), dist (psi_hat u ω i) ((ω i).1)))
    (h_cont_learn : ContinuousLearningRule n d d' learn)
    (h_cont_loss : ContinuousLoss d' loss)
    (h_bound_loss : BoundedLoss d' loss) :
    Tendsto (fun u => risk_est n d d' P learn loss (psi_hat u)) atTop (𝓝 (risk n d d' P learn loss)) := by
  -- Abbreviate the product measure.
  let μ : Measure (Fin (n + 1) → E d × Y d') := Measure.pi (fun _ : Fin (n + 1) => P)
  -- Loss (as a function of ω) converges in probability when embeddings converge in probability.
  have h_loss_dist :
      ConvergesInProbabilityToZero μ
        (fun u ω => dist (loss_est_fn n d d' learn loss psi_hat u ω)
                          (loss_true_fn n d d' learn loss ω)) := by
    simpa [μ] using
      (loss_converges_in_prob (n:=n) (d:=d) (d':=d') (P:=P) (learn:=learn) (loss:=loss)
        (psi_hat:=psi_hat) h_meas_psi h_conv h_cont_learn h_cont_loss)
  -- Turn the `dist`-statement into convergence in probability of the (real-valued) difference.
  have h_diff_prob :
      ConvergesInProbabilityToZero μ
        (fun u ω => loss_est_fn n d d' learn loss psi_hat u ω -
                    loss_true_fn n d d' learn loss ω) := by
    intro ε hε
    -- For reals, `dist a b = ‖a - b‖ = |a - b|`.
    have h0 := h_loss_dist ε hε
    -- Simplify the absolute value on the distance, and rewrite `dist` as `|a - b|`.
    -- Then the event `{ω | |a-b| > ε}` is exactly the one required by `ConvergesInProbabilityToZero`.
    simpa [μ, dist_eq_norm, Real.norm_eq_abs, abs_abs, sub_eq_add_neg] using h0
  -- Global (u-independent) bound on the loss.
  rcases h_bound_loss with ⟨M, hM0, hM⟩
  have h_bound_diff :
      ∀ u, ∀ᵐ ω ∂μ,
        |loss_est_fn n d d' learn loss psi_hat u ω -
          loss_true_fn n d d' learn loss ω| ≤ (2 * M) := by
    intro u
    refine Filter.Eventually.of_forall (fun ω => ?_)
    have h_est : |loss_est_fn n d d' learn loss psi_hat u ω| ≤ M := by
      simpa [loss_est_fn, combined_loss_fn] using hM
        (learn (fun i : Fin n =>
          (psi_hat u ω (Fin.castSucc i), (ω (Fin.castSucc i)).2))
          (psi_hat u ω (Fin.last n)))
        ((ω (Fin.last n)).2)
    have h_true : |loss_true_fn n d d' learn loss ω| ≤ M := by
      simpa [loss_true_fn, combined_loss_fn] using hM
        (learn (fun i : Fin n => ω (Fin.castSucc i)) (ω (Fin.last n)).1)
        ((ω (Fin.last n)).2)
    have h_sub : |loss_est_fn n d d' learn loss psi_hat u ω -
                  loss_true_fn n d d' learn loss ω|
                ≤ |loss_est_fn n d d' learn loss psi_hat u ω| +
                  |loss_true_fn n d d' learn loss ω| := by
        -- Use the triangle inequality on `‖a + (-b)‖` and rewrite with `Real.norm_eq_abs`.
        simpa [sub_eq_add_neg, Real.norm_eq_abs] using
          (norm_add_le (loss_est_fn n d d' learn loss psi_hat u ω)
            (-(loss_true_fn n d d' learn loss ω)))
    -- Combine the bounds.
    have : |loss_est_fn n d d' learn loss psi_hat u ω -
              loss_true_fn n d d' learn loss ω| ≤ M + M := by
      exact le_trans h_sub (add_le_add h_est h_true)
    -- Rewrite `M + M` as `2*M`.
    simpa [two_mul, add_comm, add_left_comm, add_assoc] using this
  -- Measurability of the difference.

  -- Measurability of the difference.
  have h_meas_diff :
      ∀ u, Measurable (fun ω =>
        loss_est_fn n d d' learn loss psi_hat u ω -
        loss_true_fn n d d' learn loss ω) := by
    intro u
    -- measurability of `loss_est_fn ... u`
    have h_meas_est : Measurable (loss_est_fn n d d' learn loss psi_hat u) := by
      have h_loss : Measurable (combined_loss_fn n d d' learn loss) := by
        exact (combined_loss_continuous n d d' learn loss h_cont_learn h_cont_loss).measurable
      -- measurability of the label-projection map `ω ↦ (fun i => (ω i).2)`
      have h_lbl : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (fun i : Fin (n + 1) => (ω i).2)) := by
        classical
        refine measurable_pi_iff.2 ?_
        intro i
        exact measurable_snd.comp (measurable_pi_apply i)
      have h_pair : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (psi_hat u ω, (fun i : Fin (n + 1) => (ω i).2))) := by
        exact Measurable.prodMk (h_meas_psi u) h_lbl
      simpa [loss_est_fn] using h_loss.comp h_pair
    -- measurability of `loss_true_fn`
    have h_meas_true : Measurable (loss_true_fn n d d' learn loss) := by
      have h_loss : Measurable (combined_loss_fn n d d' learn loss) := by
        exact (combined_loss_continuous n d d' learn loss h_cont_learn h_cont_loss).measurable
      have h_x : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (fun i : Fin (n + 1) => (ω i).1)) := by
        classical
        refine measurable_pi_iff.2 ?_
        intro i
        exact measurable_fst.comp (measurable_pi_apply i)
      have h_y : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (fun i : Fin (n + 1) => (ω i).2)) := by
        classical
        refine measurable_pi_iff.2 ?_
        intro i
        exact measurable_snd.comp (measurable_pi_apply i)
      have h_pair : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          ((fun i : Fin (n + 1) => (ω i).1), (fun i : Fin (n + 1) => (ω i).2))) := by
        exact Measurable.prodMk h_x h_y
      simpa [loss_true_fn] using h_loss.comp h_pair
    -- combine
    simpa using h_meas_est.sub h_meas_true

  -- L1 convergence of the absolute difference (bounded convergence via convergence in probability).

  have h_L1 :
      Tendsto (fun u =>
        ∫ ω, |loss_est_fn n d d' learn loss psi_hat u ω -
              loss_true_fn n d d' learn loss ω| ∂μ) atTop (𝓝 0) := by
    apply expectation_converges_of_prob_converges_bounded (P:=μ)
      (X:=fun u ω =>
        loss_est_fn n d d' learn loss psi_hat u ω -
        loss_true_fn n d d' learn loss ω) (M:=2*M)
      h_meas_diff h_bound_diff h_diff_prob
  -- Hence the integral of the difference tends to 0.
  have h_int_diff0 :
      Tendsto (fun u =>
        ∫ ω, (loss_est_fn n d d' learn loss psi_hat u ω -
              loss_true_fn n d d' learn loss ω) ∂μ) atTop (𝓝 0) := by
    refine squeeze_zero_norm (fun u => ?_) h_L1
    simpa using (MeasureTheory.norm_integral_le_integral_norm
      (f := fun ω =>
        loss_est_fn n d d' learn loss psi_hat u ω -
        loss_true_fn n d d' learn loss ω) (μ:=μ))

  -- Integrability (needed for rewriting integrals).
  have h_int_true : Integrable (loss_true_fn n d d' learn loss) μ := by
    -- measurability of `loss_true_fn`
    have h_meas_true : Measurable (loss_true_fn n d d' learn loss) := by
      have h_loss : Measurable (combined_loss_fn n d d' learn loss) := by
        exact (combined_loss_continuous n d d' learn loss h_cont_learn h_cont_loss).measurable
      have h_x : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (fun i : Fin (n + 1) => (ω i).1)) := by
        classical
        refine measurable_pi_iff.2 ?_
        intro i
        exact measurable_fst.comp (measurable_pi_apply i)
      have h_y : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (fun i : Fin (n + 1) => (ω i).2)) := by
        classical
        refine measurable_pi_iff.2 ?_
        intro i
        exact measurable_snd.comp (measurable_pi_apply i)
      have h_pair : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          ((fun i : Fin (n + 1) => (ω i).1), (fun i : Fin (n + 1) => (ω i).2))) := by
        exact Measurable.prodMk h_x h_y
      simpa [loss_true_fn] using h_loss.comp h_pair
    -- boundedness => integrability
    have h_const : Integrable (fun _ : (Fin (n + 1) → E d × Y d') => (M : ℝ)) μ := by
      simpa using (MeasureTheory.integrable_const (μ := μ) (c := (M : ℝ)))
    have h_as : AEStronglyMeasurable (loss_true_fn n d d' learn loss) μ :=
      Measurable.aestronglyMeasurable h_meas_true
    have h_bound :
        ∀ᵐ ω : (Fin (n + 1) → E d × Y d') ∂μ,
          ‖loss_true_fn n d d' learn loss ω‖ ≤ M := by
      refine Filter.Eventually.of_forall (fun ω => ?_)
      have habs : |loss_true_fn n d d' learn loss ω| ≤ M := by
        simpa [loss_true_fn, combined_loss_fn] using
          hM (learn (fun i : Fin n => ω (Fin.castSucc i)) (ω (Fin.last n)).1) ((ω (Fin.last n)).2)
      simpa [Real.norm_eq_abs, abs_of_nonneg hM0] using habs
    exact h_const.mono' h_as h_bound

  have h_int_est : ∀ u, Integrable (loss_est_fn n d d' learn loss psi_hat u) μ := by
    intro u
    have h_meas_est : Measurable (loss_est_fn n d d' learn loss psi_hat u) := by
      have h_loss : Measurable (combined_loss_fn n d d' learn loss) := by
        exact (combined_loss_continuous n d d' learn loss h_cont_learn h_cont_loss).measurable
      have h_lbl : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (fun i : Fin (n + 1) => (ω i).2)) := by
        classical
        refine measurable_pi_iff.2 ?_
        intro i
        exact measurable_snd.comp (measurable_pi_apply i)
      have h_pair : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (psi_hat u ω, (fun i : Fin (n + 1) => (ω i).2))) := by
        exact Measurable.prodMk (h_meas_psi u) h_lbl
      simpa [loss_est_fn] using h_loss.comp h_pair
    have h_const : Integrable (fun _ : (Fin (n + 1) → E d × Y d') => (M : ℝ)) μ := by
      simpa using (MeasureTheory.integrable_const (μ := μ) (c := (M : ℝ)))
    have h_as : AEStronglyMeasurable (loss_est_fn n d d' learn loss psi_hat u) μ :=
      Measurable.aestronglyMeasurable h_meas_est
    have h_bound :
        ∀ᵐ ω : (Fin (n + 1) → E d × Y d') ∂μ,
          ‖loss_est_fn n d d' learn loss psi_hat u ω‖ ≤ M := by
      refine Filter.Eventually.of_forall (fun ω => ?_)
      have habs : |loss_est_fn n d d' learn loss psi_hat u ω| ≤ M := by
        simpa [loss_est_fn, combined_loss_fn] using
          hM (learn (fun i : Fin n =>
            (psi_hat u ω (Fin.castSucc i), (ω (Fin.castSucc i)).2))
            (psi_hat u ω (Fin.last n))) ((ω (Fin.last n)).2)
      simpa [Real.norm_eq_abs, abs_of_nonneg hM0] using habs
    exact h_const.mono' h_as h_bound

  -- Rewrite the integral of the difference as a difference of integrals, and conclude.
  have h_sub0 :
      Tendsto (fun u =>
        (∫ ω, loss_est_fn n d d' learn loss psi_hat u ω ∂μ) -
        (∫ ω, loss_true_fn n d d' learn loss ω ∂μ)) atTop (𝓝 0) := by
    -- Use `h_int_diff0` and rewrite pointwise.
    refine h_int_diff0.congr' ?_
    refine Filter.Eventually.of_forall (fun u => ?_)
    -- rewrite `∫ (f - g) = ∫ f - ∫ g`
    have hI1 : Integrable (loss_est_fn n d d' learn loss psi_hat u) μ := h_int_est u
    have hI2 : Integrable (loss_true_fn n d d' learn loss) μ := h_int_true
    -- Start from the LHS integral and expand.
    -- (We use `sub_eq_add_neg` + `integral_add` + `integral_neg`.)
    -- Expand `∫ (f - g)` using linearity.
    calc
      (∫ ω, (loss_est_fn n d d' learn loss psi_hat u ω -
              loss_true_fn n d d' learn loss ω) ∂μ)
          = (∫ ω, (loss_est_fn n d d' learn loss psi_hat u ω +
                    (-(loss_true_fn n d d' learn loss ω))) ∂μ) := by
              simp [sub_eq_add_neg]
      _ = (∫ ω, loss_est_fn n d d' learn loss psi_hat u ω ∂μ) +
          (∫ ω, (-(loss_true_fn n d d' learn loss ω)) ∂μ) := by
              simpa using
                (MeasureTheory.integral_add (μ:=μ)
                  (f := fun ω => loss_est_fn n d d' learn loss psi_hat u ω)
                  (g := fun ω => -(loss_true_fn n d d' learn loss ω))
                  hI1 (hI2.neg))
        _ = (∫ ω, loss_est_fn n d d' learn loss psi_hat u ω ∂μ) -
            (∫ ω, loss_true_fn n d d' learn loss ω ∂μ) := by
                simp [MeasureTheory.integral_neg, sub_eq_add_neg]
  have h_risk :
      Tendsto (fun u => ∫ ω, loss_est_fn n d d' learn loss psi_hat u ω ∂μ) atTop
        (𝓝 (∫ ω, loss_true_fn n d d' learn loss ω ∂μ)) := by
    -- Add the constant `∫ loss_true` to both sides.
    have h := h_sub0.add_const (∫ ω, loss_true_fn n d d' learn loss ω ∂μ)
    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using h
  -- Translate back to `risk` / `risk_est`.
  simpa [risk, risk_est, loss_est_fn, loss_true_fn, combined_loss_fn, μ] using h_risk
/-
Theorem 1 (paper): For fixed `n`, the risk computed using estimated embeddings converges to the risk computed
using true embeddings, assuming DKPS alignment consistency and invariance to affine isometries.
-/
theorem risk_converges_fixed_n (n d d' : ℕ)
    (P : Measure (E d × Y d')) [IsProbabilityMeasure P]
    (learn : LearningRule n d d')
    (loss : LossFunction d')
    (psi_hat : ℕ → (Fin (n + 1) → E d × Y d') → Fin (n + 1) → E d)
    (h_meas_psi : ∀ u, Measurable (psi_hat u))
    (h_align : DKPSAlignmentConsistency n d d' P psi_hat)
    (h_inv : InvariantToAffineIsometries n d d' learn)
    (h_cont_learn : ContinuousLearningRule n d d' learn)
    (h_cont_loss : ContinuousLoss d' loss)
    (h_bound_loss : BoundedLoss d' loss) :
    Tendsto (fun u => risk_est n d d' P learn loss (psi_hat u)) atTop (𝓝 (risk n d d' P learn loss)) := by
  -- Use alignment consistency to pick a sequence of affine isometries so that the transformed estimates
  -- converge (in probability) to the true embeddings.
  obtain ⟨e, he⟩ := transformed_embeddings_converge (n:=n) (d:=d) (d':=d') (P:=P)
    (psi_hat:=psi_hat) h_align
  -- Apply the risk convergence lemma to the transformed embeddings.
  have h_tendsto_trans :
      Tendsto (fun u =>
        risk_est n d d' P learn loss (fun ω i => (e u).symm (psi_hat u ω i)))
        atTop (𝓝 (risk n d d' P learn loss)) := by
    refine risk_convergence_of_aligned_embeddings (n:=n) (d:=d) (d':=d') (P:=P)
      (learn:=learn) (loss:=loss)
      (psi_hat:=fun u ω i => (e u).symm (psi_hat u ω i))
      ?_ ?_ h_cont_learn h_cont_loss h_bound_loss
    · intro u
      -- measurability: composition of measurable `psi_hat u` with continuous `(e u).symm`.
      have h_meas_symm : Measurable (fun x : E d => (e u).symm x) := by
        exact Continuous.measurable (by exact (e u).symm.continuous)
      fun_prop
    · -- convergence already provided by `he`, after rewriting the `dist`.
      -- `he` is exactly the statement for the transformed embeddings.
      simpa using he
  -- Invariance to affine isometries lets us remove the transformation.
  have h_eq :
      ∀ u,
        risk_est n d d' P learn loss (psi_hat u) =
        risk_est n d d' P learn loss (fun ω i => (e u).symm (psi_hat u ω i)) := by
    intro u
    -- `risk_est_invariant` says `risk_est (e ∘ ψ) = risk_est ψ`.
    -- Apply it with `ψ := (e u)⁻¹ ∘ psi_hat u` so that `e u ∘ ψ = psi_hat u`.
    simpa using
      (risk_est_invariant (n:=n) (d:=d) (d':=d') (P:=P) (learn:=learn) (loss:=loss)
        (psi_hat:=fun ω i => (e u).symm (psi_hat u ω i)) (e:=e u) h_inv)
  -- Transfer the limit along the pointwise equality.
  refine h_tendsto_trans.congr' ?_
  refine Filter.Eventually.of_forall (fun u => (h_eq u).symm)
/-
Diagonal sequence lemma: If a(n, u) -> b(n) as u -> infinity for each n, and b(n) -> L as n -> infinity, then there exists a diagonal sequence phi(n) -> infinity such that a(n, phi(n)) -> L.
-/
lemma diagonal_convergence {α : Type*} [TopologicalSpace α] [FirstCountableTopology α]
    (a : ℕ → ℕ → α) (b : ℕ → α) (L : α)
    (h_lim_u : ∀ n, Tendsto (fun u => a n u) atTop (𝓝 (b n)))
    (h_lim_n : Tendsto b atTop (𝓝 L)) :
    ∃ phi : ℕ → ℕ, Tendsto phi atTop atTop ∧ Tendsto (fun n => a n (phi n)) atTop (𝓝 L) := by
      -- By the first-countability of α, there exists a countable neighborhood basis at L.
      obtain ⟨U, hU⟩ : ∃ U : ℕ → Set α, (∀ k, IsOpen (U k)) ∧ (∀ k, L ∈ U k) ∧ (∀ k, U (k + 1) ⊆ U k) ∧ ∀ S ∈ nhds L, ∃ k, U k ⊆ S := by
        rcases ( nhds_basis_opens L ).exists_antitone_subbasis with ⟨ U, hU₁, hU₂ ⟩;
        exact ⟨ U, fun k => hU₁ k |>.2, fun k => hU₁ k |>.1, fun k => hU₂.2 k.le_succ, fun S hS => by rcases hU₂.mem_iff.mp hS with ⟨ k, hk ⟩ ; exact ⟨ k, hk ⟩ ⟩
      generalize_proofs at *; (
      -- By the definition of $U$, we can find a sequence $\phi(n)$ such that $a(n, \phi(n)) \in U_k$ for all $n \geq N_k$.
      obtain ⟨phi, hphi⟩ : ∃ phi : ℕ → ℕ, (∀ n, n ≤ phi n) ∧ (∀ k, ∃ N, ∀ n ≥ N, a n (phi n) ∈ U k) := by
        -- By the definition of $U$, we can find a sequence $\phi(n)$ such that $a(n, \phi(n)) \in U_k$ for all $n \geq N_k$. Use this fact.
        have h_phi : ∀ k, ∃ N, ∀ n ≥ N, ∃ M, ∀ u ≥ M, a n u ∈ U k := by
          intro k
          obtain ⟨N, hN⟩ : ∃ N, ∀ n ≥ N, b n ∈ U k := by
            exact Filter.eventually_atTop.mp ( h_lim_n ( hU.1 k |> IsOpen.mem_nhds <| hU.2.1 k ) ) |> fun ⟨ N, hN ⟩ => ⟨ N, fun n hn => hN n hn ⟩
          generalize_proofs at *; (
          exact ⟨ N, fun n hn => by rcases Filter.eventually_atTop.mp ( h_lim_u n ( hU.1 k |> IsOpen.mem_nhds <| hN n hn ) ) with ⟨ M, hM ⟩ ; exact ⟨ M, fun u hu => hM u hu ⟩ ⟩)
        generalize_proofs at *; (
        choose N hN using h_phi
        generalize_proofs at *; (
        choose! M hM using hN
        generalize_proofs at *; (
        use fun n => max n (M n n) + ∑ k ∈ Finset.range (n + 1), M k n + ∑ k ∈ Finset.range (n + 1), N k + 1
        generalize_proofs at *; (
        refine' ⟨ fun n => _, fun k => _ ⟩
        generalize_proofs at *; (
        grind);
        use N k + k + 1
        generalize_proofs at *; (
        intro n hn
        specialize hM k n (by linarith) (max n (M n n) + ∑ k ∈ Finset.range (n + 1), M k n + ∑ k ∈ Finset.range (n + 1), N k + 1) (by
        linarith [ Finset.single_le_sum ( fun x _ => Nat.zero_le ( M x n ) ) ( Finset.mem_range.mpr ( by linarith : k < n + 1 ) ), Finset.single_le_sum ( fun x _ => Nat.zero_le ( N x ) ) ( Finset.mem_range.mpr ( by linarith : k < n + 1 ) ), le_max_left n ( M n n ), le_max_right n ( M n n ) ])
        generalize_proofs at *; exact hM)))))
      generalize_proofs at *; (
      refine' ⟨ phi, Filter.tendsto_atTop_mono hphi.1 tendsto_natCast_atTop_atTop, _ ⟩
      generalize_proofs at *; (
      exact fun S hS => by rcases hU.2.2.2 S hS with ⟨ k, hk ⟩ ; rcases hphi.2 k with ⟨ N, hN ⟩ ; exact Filter.eventually_atTop.2 ⟨ N, fun n hn => hk ( hN n hn ) ⟩ ;)))
/-
Theorem 2 (paper): Consistency transfer. If the learning rule is consistent under the true embeddings,
then there exists a schedule of estimation budgets such that it is consistent under the estimated embeddings.
-/
theorem consistency_transfer_dkps (d d' : ℕ)
    (P : Measure (E d × Y d')) [IsProbabilityMeasure P]
    (learn : (n : ℕ) → LearningRule n d d')
    (loss : LossFunction d')
    (psi_hat : (n : ℕ) → ℕ → (Fin (n + 1) → E d × Y d') → Fin (n + 1) → E d)
    (L : ℝ)
    (h_meas_psi : ∀ n u, Measurable (psi_hat n u))
    (h_align : ∀ n, DKPSAlignmentConsistency n d d' P (psi_hat n))
    (h_inv : ∀ n, InvariantToAffineIsometries n d d' (learn n))
    (h_cont_learn : ∀ n, ContinuousLearningRule n d d' (learn n))
    (h_cont_loss : ContinuousLoss d' loss)
    (h_bound_loss : BoundedLoss d' loss)
    (h_consistent : Tendsto (fun n => risk n d d' P (learn n) loss) atTop (𝓝 L)) :
    ∃ phi : ℕ → ℕ, Tendsto phi atTop atTop ∧
      Tendsto (fun n => risk_est n d d' P (learn n) loss (psi_hat n (phi n))) atTop (𝓝 L) := by
  -- Apply the diagonal sequence lemma to the sequences `a(n,u)` and `b(n)`.
  have h_lim_u :
      ∀ n,
        Tendsto (fun u => risk_est n d d' P (learn n) loss (psi_hat n u)) atTop
          (𝓝 (risk n d d' P (learn n) loss)) := by
    intro n
    exact risk_converges_fixed_n (n:=n) (d:=d) (d':=d') (P:=P) (learn:=learn n) (loss:=loss)
      (psi_hat:=psi_hat n) (h_meas_psi:=h_meas_psi n) (h_align:=h_align n) (h_inv:=h_inv n)
      (h_cont_learn:=h_cont_learn n) (h_cont_loss:=h_cont_loss) (h_bound_loss:=h_bound_loss)
  -- Now diagonalize to match the `n → ∞` limit.
  exact diagonal_convergence
    (a := fun n u => risk_est n d d' P (learn n) loss (psi_hat n u))
    (b := fun n => risk n d d' P (learn n) loss)
    (L := L)
    h_lim_u
    h_consistent
/-- Risk of a (measurable) decision function `h : E → Y`. -/
def risk_df (d d' : ℕ) (P : Measure (E d × Y d'))
    (loss : LossFunction d') (h : E d → Y d') : ℝ :=
  ∫ p, loss (h p.1) p.2 ∂P
/-- Bayes risk over a hypothesis class `H`. (Paper's `R^*_\ell(PψY,H)`.) -/
def bayesRisk (d d' : ℕ) (P : Measure (E d × Y d'))
    (loss : LossFunction d') (H : Set (E d → Y d')) : ℝ :=
  sInf (risk_df (d:=d) (d':=d') P loss '' H)
/-- Appendix-A style "consistency": expected risk tends to Bayes risk. -/
def ConsistentExpected (d d' : ℕ) (P : Measure (E d × Y d'))
    (loss : LossFunction d')
    (learn : (n : ℕ) → LearningRule n d d')
    (H : Set (E d → Y d')) : Prop :=
  Tendsto (fun n => risk n d d' P (learn n) loss) atTop (𝓝 (bayesRisk d d' P loss H))
theorem consistency_transfer_dkps_bayes (d d' : ℕ)
    (P : Measure (E d × Y d')) [IsProbabilityMeasure P]
    (learn : (n : ℕ) → LearningRule n d d')
    (loss : LossFunction d')
    (psi_hat : (n : ℕ) → ℕ → (Fin (n + 1) → E d × Y d') → Fin (n + 1) → E d)
    (H : Set (E d → Y d'))
    (h_meas_psi : ∀ n u, Measurable (psi_hat n u))
    (h_align : ∀ n, DKPSAlignmentConsistency n d d' P (psi_hat n))
    (h_inv : ∀ n, InvariantToAffineIsometries n d d' (learn n))
    (h_cont_learn : ∀ n, ContinuousLearningRule n d d' (learn n))
    (h_cont_loss : ContinuousLoss d' loss)
    (h_bound_loss : BoundedLoss d' loss)
    (h_consistent : ConsistentExpected d d' P loss learn H) :
    ∃ phi : ℕ → ℕ, Tendsto phi atTop atTop ∧
      Tendsto (fun n => risk_est n d d' P (learn n) loss (psi_hat n (phi n))) atTop
        (𝓝 (bayesRisk d d' P loss H)) := by
  -- Instantiate Theorem 2 with `L = bayesRisk ...`.
  simpa [ConsistentExpected] using
    (consistency_transfer_dkps (d:=d) (d':=d') (P:=P) (learn:=learn) (loss:=loss) (psi_hat:=psi_hat)
      (L := bayesRisk d d' P loss H)
      h_meas_psi h_align h_inv h_cont_learn h_cont_loss h_bound_loss h_consistent)


/-!
## Variant: replace global `BoundedLoss` with compact-support / bounded-range assumptions

This section provides a drop-in alternative to the `BoundedLoss` assumption used above.

**Idea.** If
1. the test label `y` lies almost surely in a fixed compact set `Kᵧ`, and
2. the learner's predictions always lie in a fixed compact set `K̂` (uniformly over training sets and test inputs),

then continuity of `loss` implies `loss` is bounded on `K̂ × Kᵧ`, yielding the domination constant used in the
expectation step.

This is weaker than global boundedness of `loss` (e.g. it allows squared loss), but it *is* an additional
assumption: you need some uniform bounded-range control of predictions and labels.
-/

-- Labels are (almost surely) contained in a fixed compact set.
def LabelsCompactSupport (d d' : ℕ) (P : Measure (E d × Y d')) : Prop :=
  ∃ K : Set (Y d'), IsCompact K ∧ ∀ᵐ p ∂P, p.2 ∈ K

-- Predictions of the learning rule are contained in a fixed compact set (uniformly).
def UniformlyBoundedPredictions (n d d' : ℕ) (learn : LearningRule n d d') : Prop :=
  ∃ K : Set (Y d'), IsCompact K ∧ ∀ (t : Fin n → E d × Y d') (ψ : E d), learn t ψ ∈ K

/-- If `loss` is continuous, then it is bounded on a compact product set. -/
lemma abs_loss_bounded_on_compact (d' : ℕ) (loss : LossFunction d')
    (Khat Ky : Set (Y d')) (hKhat : IsCompact Khat) (hKy : IsCompact Ky)
    (h_cont_loss : ContinuousLoss d' loss) :
    ∃ M : ℝ, 0 ≤ M ∧ ∀ yhat ∈ Khat, ∀ y ∈ Ky, |loss yhat y| ≤ M := by
  classical
  -- Compactness of the product.
  have hKprod : IsCompact (Khat ×ˢ Ky) := hKhat.prod hKy
  -- Continuity of the absolute-loss map.
  have hcont0 : Continuous (fun p : (Y d' × Y d') => loss p.1 p.2) := by
    simpa [ContinuousLoss] using h_cont_loss
  have hcont : Continuous (fun p : (Y d' × Y d') => |loss p.1 p.2|) :=
    (continuous_abs.comp hcont0)
  -- The image is compact hence bounded above.
  let S : Set ℝ := (fun p : (Y d' × Y d') => |loss p.1 p.2|) '' (Khat ×ˢ Ky)
  have hScomp : IsCompact S := hKprod.image hcont
  have hSbdd : BddAbove S := hScomp.bddAbove
  rcases hSbdd with ⟨M0, hM0⟩
  -- Make the bound nonnegative.
  refine ⟨max M0 0, le_max_right _ _, ?_⟩
  intro yhat hyhat y hy
  have hs : |loss yhat y| ∈ S := by
    refine ⟨(yhat, y), ?_, rfl⟩
    exact ⟨hyhat, hy⟩
  have hle : |loss yhat y| ≤ M0 := hM0 hs
  exact le_trans hle (le_max_left _ _)

-- NOTE: This lemma is the same as `risk_convergence_of_aligned_embeddings`, but it derives the domination
-- constant from compact-support / bounded-range assumptions instead of assuming `BoundedLoss`.
lemma risk_convergence_of_aligned_embeddings_compact (n d d' : ℕ)
    (P : Measure (E d × Y d')) [IsProbabilityMeasure P]
    (learn : LearningRule n d d')
    (loss : LossFunction d')
    (psi_hat : ℕ → (Fin (n + 1) → E d × Y d') → Fin (n + 1) → E d)
    (h_meas_psi : ∀ u, Measurable (psi_hat u))
    (h_conv : ConvergesInProbabilityToZero (Measure.pi (fun _ : Fin (n + 1) => P))
      (fun u ω => ⨆ i : Fin (n + 1), dist (psi_hat u ω i) ((ω i).1)))
    (h_cont_learn : ContinuousLearningRule n d d' learn)
    (h_cont_loss : ContinuousLoss d' loss)
    (h_lab : LabelsCompactSupport d d' P)
    (h_pred : UniformlyBoundedPredictions n d d' learn) :
    Tendsto (fun u => risk_est n d d' P learn loss (psi_hat u)) atTop (𝓝 (risk n d d' P learn loss)) := by
  -- Abbreviate the product measure.
  let μ : Measure (Fin (n + 1) → E d × Y d') := Measure.pi (fun _ : Fin (n + 1) => P)

  -- Loss (as a function of ω) converges in probability when embeddings converge in probability.
  have h_loss_dist :
      ConvergesInProbabilityToZero μ
        (fun u ω => dist (loss_est_fn n d d' learn loss psi_hat u ω)
                          (loss_true_fn n d d' learn loss ω)) := by
    simpa [μ] using
      (loss_converges_in_prob (n:=n) (d:=d) (d':=d') (P:=P) (learn:=learn) (loss:=loss)
        (psi_hat:=psi_hat) h_meas_psi h_conv h_cont_learn h_cont_loss)

  -- Turn the `dist`-statement into convergence in probability of the (real-valued) difference.
  have h_diff_prob :
      ConvergesInProbabilityToZero μ
        (fun u ω => loss_est_fn n d d' learn loss psi_hat u ω -
                    loss_true_fn n d d' learn loss ω) := by
    intro ε hε
    have h0 := h_loss_dist ε hε
    simpa [μ, dist_eq_norm, Real.norm_eq_abs, abs_abs, sub_eq_add_neg] using h0

  -- Extract compact sets for labels and predictions and derive a domination constant.
  rcases h_lab with ⟨Ky, hKy_comp, hKy_ae⟩
  rcases h_pred with ⟨Khat, hKhat_comp, hKhat⟩
  rcases abs_loss_bounded_on_compact (d':=d') (loss:=loss) (Khat:=Khat) (Ky:=Ky)
      hKhat_comp hKy_comp h_cont_loss with ⟨M, hM0, hM⟩

  -- The test label is in Ky almost surely under μ (lift from P to the product measure).
  have h_test_label :
      ∀ᵐ ω : (Fin (n + 1) → E d × Y d') ∂μ, (ω (Fin.last n)).2 ∈ Ky := by
    -- Base a.e. statement under the marginal P
    have h_each : ∀ᵐ p : (E d × Y d') ∂P, p.2 ∈ Ky := hKy_ae

    -- `eval i` sends μ-a.e. to P-a.e. (i.e. the i-th marginal is P)
    have ht :
        Filter.Tendsto (Function.eval (Fin.last n))
          (MeasureTheory.ae μ) (MeasureTheory.ae P) := by
      -- IMPORTANT: this lemma is for `Measure.pi` families; here the family is constant `P`.
      -- If your elaborator wants it explicit, keep the `(μ := fun _ => P)` argument.
      simpa [μ] using
        (MeasureTheory.Measure.tendsto_eval_ae_ae
          (μ := fun _ : Fin (n + 1) => P) (i := Fin.last n))

    -- Pull back the P-a.e. fact along `eval (last n)`
    exact (ht.eventually h_each).mono (by
      intro ω hω
      simpa using hω)

  -- Global (u-independent) bound on the loss difference (almost surely).
  have h_bound_diff :
      ∀ u, ∀ᵐ ω ∂μ,
        |loss_est_fn n d d' learn loss psi_hat u ω -
          loss_true_fn n d d' learn loss ω| ≤ (2 * M) := by
    intro u
    filter_upwards [h_test_label] with ω hy
    have h_est : |loss_est_fn n d d' learn loss psi_hat u ω| ≤ M := by
      -- bound by compactness: prediction in Khat, label in Ky
      have hyhat : learn
          (fun i : Fin n =>
            (psi_hat u ω (Fin.castSucc i), (ω (Fin.castSucc i)).2))
          (psi_hat u ω (Fin.last n)) ∈ Khat :=
        hKhat _ _
      have : |loss
          (learn
            (fun i : Fin n =>
              (psi_hat u ω (Fin.castSucc i), (ω (Fin.castSucc i)).2))
            (psi_hat u ω (Fin.last n)))
          ((ω (Fin.last n)).2)| ≤ M :=
        hM _ hyhat _ hy
      simpa [loss_est_fn, combined_loss_fn] using this
    have h_true : |loss_true_fn n d d' learn loss ω| ≤ M := by
      have hyhat : learn (fun i : Fin n => ω (Fin.castSucc i)) (ω (Fin.last n)).1 ∈ Khat :=
        hKhat _ _
      have : |loss (learn (fun i : Fin n => ω (Fin.castSucc i)) (ω (Fin.last n)).1) ((ω (Fin.last n)).2)| ≤ M :=
        hM _ hyhat _ hy
      simpa [loss_true_fn, combined_loss_fn] using this
    have h_sub : |loss_est_fn n d d' learn loss psi_hat u ω -
                  loss_true_fn n d d' learn loss ω|
                ≤ |loss_est_fn n d d' learn loss psi_hat u ω| +
                  |loss_true_fn n d d' learn loss ω| := by
        simpa [sub_eq_add_neg, Real.norm_eq_abs] using
          (norm_add_le (loss_est_fn n d d' learn loss psi_hat u ω)
            (-(loss_true_fn n d d' learn loss ω)))
    have : |loss_est_fn n d d' learn loss psi_hat u ω -
              loss_true_fn n d d' learn loss ω| ≤ M + M := by
      exact le_trans h_sub (add_le_add h_est h_true)
    simpa [two_mul, add_comm, add_left_comm, add_assoc] using this

  -- Measurability of the difference.
  have h_meas_diff :
      ∀ u, Measurable (fun ω =>
        loss_est_fn n d d' learn loss psi_hat u ω -
        loss_true_fn n d d' learn loss ω) := by
    intro u
    have h_meas_est : Measurable (loss_est_fn n d d' learn loss psi_hat u) := by
      have h_loss : Measurable (combined_loss_fn n d d' learn loss) := by
        exact (combined_loss_continuous n d d' learn loss h_cont_learn h_cont_loss).measurable
      have h_lbl : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (fun i : Fin (n + 1) => (ω i).2)) := by
        classical
        refine measurable_pi_iff.2 ?_
        intro i
        exact measurable_snd.comp (measurable_pi_apply i)
      have h_pair : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (psi_hat u ω, (fun i : Fin (n + 1) => (ω i).2))) :=
        Measurable.prodMk (h_meas_psi u) h_lbl
      simpa [loss_est_fn] using h_loss.comp h_pair
    have h_meas_true : Measurable (loss_true_fn n d d' learn loss) := by
      have h_loss : Measurable (combined_loss_fn n d d' learn loss) := by
        exact (combined_loss_continuous n d d' learn loss h_cont_learn h_cont_loss).measurable
      have h_x : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (fun i : Fin (n + 1) => (ω i).1)) := by
        classical
        refine measurable_pi_iff.2 ?_
        intro i
        exact measurable_fst.comp (measurable_pi_apply i)
      have h_y : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (fun i : Fin (n + 1) => (ω i).2)) := by
        classical
        refine measurable_pi_iff.2 ?_
        intro i
        exact measurable_snd.comp (measurable_pi_apply i)
      have h_pair : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          ((fun i : Fin (n + 1) => (ω i).1), (fun i : Fin (n + 1) => (ω i).2))) :=
        Measurable.prodMk h_x h_y
      simpa [loss_true_fn] using h_loss.comp h_pair
    simpa using h_meas_est.sub h_meas_true

  -- L1 convergence of the absolute difference (bounded convergence via convergence in probability).
  have h_L1 :
      Tendsto (fun u =>
        ∫ ω, |loss_est_fn n d d' learn loss psi_hat u ω -
              loss_true_fn n d d' learn loss ω| ∂μ) atTop (𝓝 0) := by
    apply expectation_converges_of_prob_converges_bounded (P:=μ)
      (X:=fun u ω =>
        loss_est_fn n d d' learn loss psi_hat u ω -
        loss_true_fn n d d' learn loss ω) (M:=2*M)
      h_meas_diff h_bound_diff h_diff_prob

  -- Hence the integral of the difference tends to 0.
  have h_int_diff0 :
      Tendsto (fun u =>
        ∫ ω, (loss_est_fn n d d' learn loss psi_hat u ω -
              loss_true_fn n d d' learn loss ω) ∂μ) atTop (𝓝 0) := by
    refine squeeze_zero_norm (fun u => ?_) h_L1
    simpa using (MeasureTheory.norm_integral_le_integral_norm
      (f := fun ω =>
        loss_est_fn n d d' learn loss psi_hat u ω -
        loss_true_fn n d d' learn loss ω) (μ:=μ))

  -- Integrability (needed for rewriting integrals).
  have h_int_true : Integrable (loss_true_fn n d d' learn loss) μ := by
    have h_meas_true : Measurable (loss_true_fn n d d' learn loss) := by
      have h_loss : Measurable (combined_loss_fn n d d' learn loss) := by
        exact (combined_loss_continuous n d d' learn loss h_cont_learn h_cont_loss).measurable
      have h_x : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (fun i : Fin (n + 1) => (ω i).1)) := by
        classical
        refine measurable_pi_iff.2 ?_
        intro i
        exact measurable_fst.comp (measurable_pi_apply i)
      have h_y : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (fun i : Fin (n + 1) => (ω i).2)) := by
        classical
        refine measurable_pi_iff.2 ?_
        intro i
        exact measurable_snd.comp (measurable_pi_apply i)
      have h_pair : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          ((fun i : Fin (n + 1) => (ω i).1), (fun i : Fin (n + 1) => (ω i).2))) :=
        Measurable.prodMk h_x h_y
      simpa [loss_true_fn] using h_loss.comp h_pair
    have h_const : Integrable (fun _ : (Fin (n + 1) → E d × Y d') => (M : ℝ)) μ := by
      simpa using (MeasureTheory.integrable_const (μ := μ) (c := (M : ℝ)))
    have h_as : AEStronglyMeasurable (loss_true_fn n d d' learn loss) μ :=
      Measurable.aestronglyMeasurable h_meas_true
    have h_bound :
        ∀ᵐ ω : (Fin (n + 1) → E d × Y d') ∂μ,
          ‖loss_true_fn n d d' learn loss ω‖ ≤ M := by
      filter_upwards [h_test_label] with ω hy
      have hyhat : learn (fun i : Fin n => ω (Fin.castSucc i)) (ω (Fin.last n)).1 ∈ Khat :=
        hKhat _ _
      have habs : |loss (learn (fun i : Fin n => ω (Fin.castSucc i)) (ω (Fin.last n)).1) ((ω (Fin.last n)).2)| ≤ M :=
        hM _ hyhat _ hy
      -- turn abs-bound into norm-bound
      simpa [loss_true_fn, combined_loss_fn, Real.norm_eq_abs, abs_of_nonneg hM0] using habs
    exact h_const.mono' h_as h_bound

  have h_int_est : ∀ u, Integrable (loss_est_fn n d d' learn loss psi_hat u) μ := by
    intro u
    have h_meas_est : Measurable (loss_est_fn n d d' learn loss psi_hat u) := by
      have h_loss : Measurable (combined_loss_fn n d d' learn loss) := by
        exact (combined_loss_continuous n d d' learn loss h_cont_learn h_cont_loss).measurable
      have h_lbl : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (fun i : Fin (n + 1) => (ω i).2)) := by
        classical
        refine measurable_pi_iff.2 ?_
        intro i
        exact measurable_snd.comp (measurable_pi_apply i)
      have h_pair : Measurable (fun ω : (Fin (n + 1) → E d × Y d') =>
          (psi_hat u ω, (fun i : Fin (n + 1) => (ω i).2))) :=
        Measurable.prodMk (h_meas_psi u) h_lbl
      simpa [loss_est_fn] using h_loss.comp h_pair
    have h_const : Integrable (fun _ : (Fin (n + 1) → E d × Y d') => (M : ℝ)) μ := by
      simpa using (MeasureTheory.integrable_const (μ := μ) (c := (M : ℝ)))
    have h_as : AEStronglyMeasurable (loss_est_fn n d d' learn loss psi_hat u) μ :=
      Measurable.aestronglyMeasurable h_meas_est
    have h_bound :
        ∀ᵐ ω : (Fin (n + 1) → E d × Y d') ∂μ,
          ‖loss_est_fn n d d' learn loss psi_hat u ω‖ ≤ M := by
      filter_upwards [h_test_label] with ω hy
      have hyhat : learn
          (fun i : Fin n =>
            (psi_hat u ω (Fin.castSucc i), (ω (Fin.castSucc i)).2))
          (psi_hat u ω (Fin.last n)) ∈ Khat :=
        hKhat _ _
      have habs : |loss
          (learn
            (fun i : Fin n =>
              (psi_hat u ω (Fin.castSucc i), (ω (Fin.castSucc i)).2))
            (psi_hat u ω (Fin.last n)))
          ((ω (Fin.last n)).2)| ≤ M :=
        hM _ hyhat _ hy
      simpa [loss_est_fn, combined_loss_fn, Real.norm_eq_abs, abs_of_nonneg hM0] using habs
    exact h_const.mono' h_as h_bound

  -- Rewrite the integral of the difference as a difference of integrals, and conclude.
  have h_sub0 :
      Tendsto (fun u =>
        (∫ ω, loss_est_fn n d d' learn loss psi_hat u ω ∂μ) -
        (∫ ω, loss_true_fn n d d' learn loss ω ∂μ)) atTop (𝓝 0) := by
    refine h_int_diff0.congr' ?_
    refine Filter.Eventually.of_forall (fun u => ?_)
    have hI1 : Integrable (loss_est_fn n d d' learn loss psi_hat u) μ := h_int_est u
    have hI2 : Integrable (loss_true_fn n d d' learn loss) μ := h_int_true
    calc
      (∫ ω, (loss_est_fn n d d' learn loss psi_hat u ω -
              loss_true_fn n d d' learn loss ω) ∂μ)
          = (∫ ω, (loss_est_fn n d d' learn loss psi_hat u ω +
                    (-(loss_true_fn n d d' learn loss ω))) ∂μ) := by
              simp [sub_eq_add_neg]
      _ = (∫ ω, loss_est_fn n d d' learn loss psi_hat u ω ∂μ) +
          (∫ ω, (-(loss_true_fn n d d' learn loss ω)) ∂μ) := by
              simpa using
                (MeasureTheory.integral_add (μ:=μ)
                  (f := fun ω => loss_est_fn n d d' learn loss psi_hat u ω)
                  (g := fun ω => -(loss_true_fn n d d' learn loss ω))
                  hI1 (hI2.neg))
      _ = (∫ ω, loss_est_fn n d d' learn loss psi_hat u ω ∂μ) -
            (∫ ω, loss_true_fn n d d' learn loss ω ∂μ) := by
                simp [MeasureTheory.integral_neg, sub_eq_add_neg]

  have h_risk :
      Tendsto (fun u => ∫ ω, loss_est_fn n d d' learn loss psi_hat u ω ∂μ) atTop
        (𝓝 (∫ ω, loss_true_fn n d d' learn loss ω ∂μ)) := by
    have h := h_sub0.add_const (∫ ω, loss_true_fn n d d' learn loss ω ∂μ)
    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using h

  simpa [risk, risk_est, loss_est_fn, loss_true_fn, combined_loss_fn, μ] using h_risk

/-- Compact-support / bounded-range variant of Theorem 1. -/
theorem risk_converges_fixed_n_compact (n d d' : ℕ)
    (P : Measure (E d × Y d')) [IsProbabilityMeasure P]
    (learn : LearningRule n d d')
    (loss : LossFunction d')
    (psi_hat : ℕ → (Fin (n + 1) → E d × Y d') → Fin (n + 1) → E d)
    (h_meas_psi : ∀ u, Measurable (psi_hat u))
    (h_align : DKPSAlignmentConsistency n d d' P psi_hat)
    (h_inv : InvariantToAffineIsometries n d d' learn)
    (h_cont_learn : ContinuousLearningRule n d d' learn)
    (h_cont_loss : ContinuousLoss d' loss)
    (h_lab : LabelsCompactSupport d d' P)
    (h_pred : UniformlyBoundedPredictions n d d' learn) :
    Tendsto (fun u => risk_est n d d' P learn loss (psi_hat u)) atTop (𝓝 (risk n d d' P learn loss)) := by
  obtain ⟨e, he⟩ := transformed_embeddings_converge (n:=n) (d:=d) (d':=d') (P:=P)
    (psi_hat:=psi_hat) h_align
  have h_tendsto_trans :
      Tendsto (fun u =>
        risk_est n d d' P learn loss (fun ω i => (e u).symm (psi_hat u ω i)))
        atTop (𝓝 (risk n d d' P learn loss)) := by
    refine risk_convergence_of_aligned_embeddings_compact (n:=n) (d:=d) (d':=d') (P:=P)
      (learn:=learn) (loss:=loss)
      (psi_hat:=fun u ω i => (e u).symm (psi_hat u ω i))
      ?_ ?_ h_cont_learn h_cont_loss h_lab h_pred
    · intro u
      have h_meas_symm : Measurable (fun x : E d => (e u).symm x) := by
        exact Continuous.measurable (by exact (e u).symm.continuous)
      fun_prop
    · simpa using he
  have h_eq :
      ∀ u,
        risk_est n d d' P learn loss (psi_hat u) =
        risk_est n d d' P learn loss (fun ω i => (e u).symm (psi_hat u ω i)) := by
    intro u
    simpa using
      (risk_est_invariant (n:=n) (d:=d) (d':=d') (P:=P) (learn:=learn) (loss:=loss)
        (psi_hat:=fun ω i => (e u).symm (psi_hat u ω i)) (e:=e u) h_inv)
  refine h_tendsto_trans.congr' ?_
  refine Filter.Eventually.of_forall (fun u => (h_eq u).symm)
